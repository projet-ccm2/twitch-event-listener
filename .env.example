# ==========================================
# 1. DEV MOCK (Local development, no Twitch)
# Copy this section to .env for local testing without internet/Twitch
# ==========================================
# NODE_ENV=local
# PORT=3000
# USE_MOCK=true
# DISPATCHER_URL=http://localhost:4000/events
# ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,null

# ==========================================
# 2. DEV NO MOCK (Local development, real Twitch)
# Requires a public URL (e.g., ngrok) for Webhooks
# ==========================================
# NODE_ENV=local
# PORT=3000
# USE_MOCK=false
# DISPATCHER_URL=http://localhost:4000/events
# ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,null
#
# Twitch Credentials
# TWITCH_CLIENT_ID=your_twitch_client_id
# TWITCH_CLIENT_SECRET=your_twitch_client_secret
# TWITCH_WEBHOOK_SECRET=your_webhook_secret
# PUBLIC_EVENTSUB_CALLBACK=https://your-ngrok-url.ngrok-free.app

# ==========================================
# 3. PRODUCTION
# ==========================================
# Real deployment with connection to DB Service
# ==========================================
# NODE_ENV=production
# PORT=3000
# USE_MOCK=false
#
# Service Communication
# DISPATCHER_URL=http://backend-api/events
# DB_SERVICE_URL=http://db-service/listeners
# SYNC_INTERVAL_MS=60000
# ALLOWED_ORIGINS=https://mydomain.com
#
# Twitch Credentials
# TWITCH_CLIENT_ID=prod_client_id
# TWITCH_CLIENT_SECRET=prod_client_secret
# TWITCH_WEBHOOK_SECRET=prod_webhook_secret
# PUBLIC_EVENTSUB_CALLBACK=https://api.mydomain.com
